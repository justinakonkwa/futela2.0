# Copiez ce fichier en key.properties et remplissez les valeurs.
# ⚠️ NE COMMITEZ JAMAIS key.properties (déjà dans .gitignore)

storePassword=VOTRE_MOT_DE_PASSE_KEYSTORE
keyPassword=VOTRE_MOT_DE_PASSE_CLE
keyAlias=upload
# Chemin absolu vers le fichier .jks (sur Windows utilisez \\ dans le chemin)
storeFile=/Users/VOTRE_NOM/upload-keystore.jks
